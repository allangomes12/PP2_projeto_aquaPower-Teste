<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
</head>
<body>
    <h1>Editar Usuário</h1>

<form action="/usuarios/update" method="POST">

    <input type="hidden" name="id" value="{{usuario.id}}">

    <label>Nome:</label>
    <input
        type="text"
        name="nome"
        value="{{usuario.nome}}">

    <label>Email:</label>
    <input
        type="email"
        name="email"
        value="{{usuario.email}}">

    <label>Senha:</label>
    <input
        type="password"
        name="senha"
        value="{{usuario.senha}}">

    <button>Salvar</button>

</form>
</body>
</html>
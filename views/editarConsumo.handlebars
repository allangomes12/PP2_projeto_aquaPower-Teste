<!DOCTYPE html>
<html lang="pt-BR">

<head>

    <meta charset="UTF-8">

    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>Editar Consumo | AquaPower</title>

    <link rel="stylesheet" href="/css/home.css">

    <link rel="preconnect" href="https://fonts.googleapis.com">

    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>

    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">

</head>

<body>

<header>

    <div class="logoCompleta">

        <img src="/img/LogoFoto.png" alt="Logo AquaPower">

        <h1>

            <span class="aqua">Aqua</span><span class="power">Power</span>

        </h1>

    </div>

</header>

<div class="paginaCadastro">

    <div class="cardCadastro">

        <h2>Editar Consumo</h2>

        <p>

            Atualize as informações do consumo cadastrado.

        </p>

        <form action="/consumos/update" method="POST">

            <input
                type="hidden"
                name="id"
                value="{{consumo.id}}">

            <label>Tipo</label>

            <input
                type="text"
                name="tipo"
                value="{{consumo.tipo}}"
                required>

            <label>Mês</label>

            <input
                type="text"
                name="mes"
                value="{{consumo.mes}}"
                required>

            <label>Ano</label>

            <input
                type="number"
                name="ano"
                value="{{consumo.ano}}"
                required>

            <label>Valor</label>

            <input
                type="number"
                step="0.01"
                name="valor"
                value="{{consumo.valor}}"
                required>

            <button type="submit">

                Salvar Alterações

            </button>

        </form>

        <a href="/" class="voltar">

            ← Voltar para a Home

        </a>

    </div>

</div>

</body>

</html>
<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
</head>

<body>
    <h1>Editar Consumo</h1>

    <form action="/consumos/update" method="POST">

        <input type="hidden" name="id" value="{{consumo.id}}">

        <label>Tipo</label>

        <select name="tipo">

            <option value="Água">Água</option>

            <option value="Energia">Energia</option>

        </select>

        <br><br>

        <label>Mês</label>

        <input type="text" name="mes" value="{{consumo.mes}}">

        <br><br>

        <label>Ano</label>

        <input type="number" name="ano" value="{{consumo.ano}}">

        <br><br>

        <label>Valor</label>

        <input type="number" step="0.01" name="valor" value="{{consumo.valor}}">

        <br><br>

        <button>

            Salvar Alterações

        </button>

    </form>
</body>

</html>
<!DOCTYPE html>
<html lang="pt-BR">

<head>

    <meta charset="UTF-8">

    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>Novo Consumo | AquaPower</title>

    <link rel="stylesheet" href="/css/home.css">

    <link rel="preconnect" href="https://fonts.googleapis.com">

    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>

    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">

</head>

<body>

<header>

    <div class="logoCompleta">

        <img src="/img/LogoFoto.png" alt="Logo">

        <h1>

            <span class="aqua">Aqua</span><span class="power">Power</span>

        </h1>

    </div>

</header>

<div class="paginaCadastro">

    <div class="cardCadastro">

        <h2>Novo Consumo</h2>

        <p>

            Registre um novo consumo de água ou energia.

        </p>

        <form action="/consumos/add" method="POST">

            <label>Tipo</label>

            <select name="tipo">

                <option value="Água">Água</option>

                <option value="Energia">Energia</option>

            </select>

            <label>Mês</label>

            <select name="mes">

                <option>Janeiro</option>
                <option>Fevereiro</option>
                <option>Março</option>
                <option>Abril</option>
                <option>Maio</option>
                <option>Junho</option>
                <option>Julho</option>
                <option>Agosto</option>
                <option>Setembro</option>
                <option>Outubro</option>
                <option>Novembro</option>
                <option>Dezembro</option>

            </select>

            <label>Ano</label>

            <select name="ano">

                <option>2025</option>
                <option>2026</option>
                <option>2027</option>

            </select>

            <label>Valor</label>

            <input
                type="number"
                step="0.01"
                name="valor"
                placeholder="Ex: 120.50"
                required>

            <button type="submit">

                Salvar Consumo

            </button>

        </form>

        <a class="voltar" href="/">

            ← Voltar para a Home

        </a>

    </div>

</div>

</body>

</html>